<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>The Dogs Online (Firestore Version)</title>
    <style>
        body { font-family: sans-serif; background-color: #2c3e50; color: white; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        #board { display: grid; grid-template-columns: repeat(9, 60px); grid-template-rows: repeat(8, 60px); border: 4px solid #1a252f; gap: 2px; }
        .square { width: 60px; height: 60px; display: flex; justify-content: center; align-items: center; font-size: 35px; cursor: pointer; }
        .white { background-color: #ecf0f1; }
        .black { background-color: #7f8c8d; }
        .selected { outline: 4px solid #e74c3c; outline-offset: -4px; }
    </style>
</head>
<body>

    <h1>The Dogs Online</h1>
    <div id="role-display">Loading...</div>
    <div id="status">Syncing with Firestore...</div>
    <div id="board"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, doc, setDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        // --- PASTE YOUR FIREBASE CONFIG HERE ---
        const firebaseConfig = {
            apiKey: "AIzaSyA15FP1irwq2HLOjMqtS93Z_ToE8xWnMvQ",
            authDomain: "dogs-online.firebaseapp.com",
            projectId: "dogs-online",
            storageBucket: "dogs-online.firebasestorage.app",
            messagingSenderId: "460621226118",
            appId: "1:460621226118:web:8db2580e4cc06b75743107"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const gameDoc = doc(db, "games", "dogs_game_1");

        const urlParams = new URLSearchParams(window.location.search);
        const myRole = urlParams.get('role');
        document.getElementById('role-display').innerText = `You are: ${myRole ? myRole.toUpperCase() : 'SPECTATOR'}`;

        let board = [];
        let currentPlayer = 'white';
        let selectedSquare = null;

        // Listen to Firestore for moves
        onSnapshot(gameDoc, (snapshot) => {
            if (snapshot.exists()) {
                const data = snapshot.data();
                board = data.board;
                currentPlayer = data.currentPlayer;
                renderBoard();
            } else {
                initNewGame();
            }
        });

        async function initNewGame() {
            let b = Array(8).fill(null).map(() => Array(9).fill(null));
            // Basic setup logic
            for(let r=0; r<2; r++) for(let c=0; c<9; c++) if((r+c)%2===0) b[r][c]='black';
            for(let r=6; r<8; r++) for(let c=0; c<9; c++) if((r+c)%2!==0) b[r][c]='white';
            await setDoc(gameDoc, { board: b, currentPlayer: 'white' });
        }

        function renderBoard() {
            const boardEl = document.getElementById('board');
            boardEl.innerHTML = '';
            document.getElementById('status').innerText = `${currentPlayer.toUpperCase()}'s Turn`;
            
            for (let r = 0; r < 8; r++) {
                for (let c = 0; c < 9; c++) {
                    const sq = document.createElement('div');
                    sq.className = `square ${(r+c)%2===0 ? 'white' : 'black'}`;
                    sq.innerHTML = board[r][c] === 'white' ? '🐩' : (board[r][c] === 'black' ? '🐕‍🦺' : '');
                    sq.onclick = () => handleSquareClick(r, c);
                    boardEl.appendChild(sq);
                }
            }
        }

        async function handleSquareClick(r, c) {
            if (myRole !== currentPlayer) return;
async function handleSquareClick(r, c) {
    if (myRole !== currentPlayer) return; // Not your turn

    const clickedPiece = board[r][c];

    // 1. Select your own piece
    if (clickedPiece === currentPlayer) {
        selectedSquare = { r, c };
        renderBoard();
        return;
    }

    // 2. Try to move to an empty square
    if (selectedSquare && !clickedPiece && isValidMove(selectedSquare.r, selectedSquare.c, r, c)) {
        // Create a copy of the board to modify
        let newBoard = JSON.parse(JSON.stringify(board));
        
        newBoard[r][c] = currentPlayer;
        newBoard[selectedSquare.r][selectedSquare.c] = null;
        
        selectedSquare = null;
        
        // Check for captures before sending to Firestore
        await handleCaptures(newBoard, r, c);
    } else {
        selectedSquare = null;
        renderBoard();
    }
}

function isValidMove(startR, startC, endR, endC) {
    const targetIsWhiteSquare = (endR + endC) % 2 === 0;
    // White dogs only on Black squares, Black dogs only on White squares
    if (currentPlayer === 'white' && targetIsWhiteSquare) return false;
    if (currentPlayer === 'black' && !targetIsWhiteSquare) return false;

    const rowDiff = Math.abs(startR - endR);
    const colDiff = Math.abs(startC - endC);
    return rowDiff === 1 && colDiff === 1;
}

async function handleCaptures(newBoard, r, c) {
    const opponent = currentPlayer === 'white' ? 'black' : 'white';
    const diagonals = [[-1, -1], [-1, 1], [1, -1], [1, 1]];
    let capturedAny = false;

    for (const dir of diagonals) {
        const diagR = r + dir[0];
        const diagC = c + dir[1];

        if (diagR >= 0 && diagR < 8 && diagC >= 0 && diagC < 9) {
            // If we find another of our pieces at a corner
            if (newBoard[diagR][diagC] === currentPlayer) {
                const targets = [
                    {tr: r + dir[0], tc: c}, 
                    {tr: r, tc: c + dir[1]}
                ];

                for (const t of targets) {
                    if (t.tr >= 0 && t.tr < 8 && t.tc >= 0 && t.tc < 9 && newBoard[t.tr][t.tc] === opponent) {
                        const wantsToFlip = confirm("You pinched a Dog! OK to Flip it to your side, Cancel to remove it.");
                        
                        newBoard[t.tr][t.tc] = null;
                        if (wantsToFlip) {
                            const flipTo = findClosestValidSquare(newBoard, t.tr, t.tc, currentPlayer);
                            if (flipTo) newBoard[flipTo.r][flipTo.c] = currentPlayer;
                        }
                        capturedAny = true;
                    }
                }
            }
        }
    }

    // Switch turn and update Firestore
    const nextPlayer = currentPlayer === 'white' ? 'black' : 'white';
    await setDoc(gameDoc, { board: newBoard, currentPlayer: nextPlayer });
}

function findClosestValidSquare(tempBoard, r, c, forPlayer) {
    let minDistance = Infinity;
    let bestSquare = null;

    for (let i = 0; i < 8; i++) {
        for (let j = 0; j < 9; j++) {
            const isWhiteSquare = (i + j) % 2 === 0;
            const isValidColor = forPlayer === 'black' ? isWhiteSquare : !isWhiteSquare;

            if (tempBoard[i][j] === null && isValidColor) {
                const dist = Math.abs(i - r) + Math.abs(j - c);
                if (dist < minDistance) {
                    minDistance = dist;
                    bestSquare = { r: i, c: j };
                }
            }
        }
    }
    return bestSquare;
}
        }
    </script>
</body>
</html>
